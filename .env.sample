# Example .env file for Craft Fusion
#
# Copy this file to .env and fill in your real secrets for local development.
# Do NOT commit your real .env file to version control.

# --- API Keys and Tokens ---

# Mapbox (required for map visualizations)
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here

# OpenSky API credentials (optional, demo is public)
OPENSKY_USERNAME=demo
OPENSKY_PASSWORD=demo

# Yahoo Finance API (used for financial data)
YAHOO_FINANCE_API_KEY=your-yahoo-finance-api-key-here

# Finnhub API (used for stock/financial data)
FINNHUB_API_KEY=your-finnhub-api-key-here

# NASA FIRMS API (used for fire alerts)
NASA_FIRMS_API_KEY=your-nasa-firms-api-key-here

# Alpha Vantage API (used for financial data)
ALPHA_VANTAGE_API_KEY=demo

# OpenAI API Key (server-side, for AI features)
OPENAI_API_KEY=your-openai-api-key-here

# --- Application Secrets ---

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=3600
ADMIN_SECRET=your-admin-secret-here
REFRESH_TOKEN_EXPIRATION=604800

# Example valued member token (for demo/testing)
VALUED_MEMBER_TOKEN=your-valued-member-jwt-here
VALUED_MEMBER_USERNAME=valued-member
VALUED_MEMBER_ROLES=user

# --- Other Environment Variables ---

LOG_LEVEL=debug
MONGODB_MEMORY_PORT=27018

# --- Local/Dev URLs ---

# Socket server URL
SOCKET_URL=http://localhost:3000
