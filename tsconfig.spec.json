{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc/spec",
    "types": ["jest", "node"],
    "allowJs": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node"
  },
  "files": ["test-setup.ts"],
  "include": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.d.ts"
  ]
}
